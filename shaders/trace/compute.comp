#ifdef HEATMAP
#extension GL_ARB_shader_clock : enable
#extension GL_NV_gpu_shader5 : enable
#endif
void main(){
#ifdef HEATMAP
    uint64_t startTime = clockARB(); // Requires GL_ARB_shader_clock
#endif   
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    
    // get screen size
    ivec2 size = imageSize(imgOutput);
    if(pixel.x >= size.x || pixel.y >= size.y)
        return;

    {   // rng initialization
        // can't start at 0                             random prime number
        // Poor rng initialization
        //uint initSeed = (1u + pixel.x + pixel.y * size.x);
        //initSeed += frameNumber * 1299827u;

        uint pixelHash = pixel.x * 73856093u 
                   ^ pixel.y * 19349663u 
                   ^ frameNumber * 83492791u;

        InitializeSeed(pixelHash);
    }
    // coords from 0-1
    // reverse the V coord
    float u = (float(pixel.x) + RandomFloat()) / float(size.x);
    float v = (float(pixel.y) + RandomFloat()) / float(size.y);


    // get ray dir
    // point on the screen-plane
    vec3 point = cTopLeft + 
                    u * (cTopRight - cTopLeft) + 
                    v * (cBottomLeft - cTopLeft); 

    // global ray can be used for initial intersection
    Ray ray;
    ray.o = camPos;
    ray.d = normalize(point - camPos);
    // important step
    ray.t = 1e30;

    

    vec4 finalColor = vec4(0.0,0.0,0.0,1.0);
    vec3 throughput = vec3(1.0);


    if(maxBounce == 0){
        HitInfo hitInfo;
        Trace(ray, hitInfo);
        
        if(hitInfo.voxelID == 0){
            // equirectangular panorama texture sampling with ray.d
            // https://jacco.ompf2.com/2022/05/27/how-to-build-a-bvh-part-8-whitted-style/
            float domeu = (atan(ray.d.z,ray.d.x) * INV2PI + 0.5);
            float domev = (acos(ray.d.y) * INVPI);
            vec4 backGroundColor =  texture(skydome,vec2(domeu,domev));

            finalColor.xyz += throughput * backGroundColor.xyz;
        }
        else
            finalColor.xyz = materialData[hitInfo.voxelID].color;

        imageStore(imgOutput,pixel, finalColor);
        return;
    }
    
    for(int bounce = 0; bounce <= maxBounce; bounce++){
        
        HitInfo hitInfo;
        Trace(ray, hitInfo);
        
        if(hitInfo.voxelID == 0){
            // equirectangular panorama texture sampling with ray.d
            // https://jacco.ompf2.com/2022/05/27/how-to-build-a-bvh-part-8-whitted-style/
            float domeu = (atan(ray.d.z,ray.d.x) * INV2PI + 0.5);
            float domev = (acos(ray.d.y) * INVPI);
            vec4 backGroundColor =  texture(skydome,vec2(domeu,domev));

            finalColor.xyz += throughput * backGroundColor.xyz;
            break;
        }

        
        vec3 albedo = materialData[hitInfo.voxelID].color;
        
        vec3 I = ray.o + ray.d * ray.t;
        vec3 normal = hitInfo.normal;
        
        // https://jacco.ompf2.com/2024/05/29/ray-tracing-with-voxels-in-c-series-part-6/
        vec3 brdf = albedo * INVPI;

        vec3 c1 = cross(normal, vec3(0.0, 0.0, 1.0));
        vec3 c2 = cross(normal, vec3(0.0, 1.0, 0.0));

        vec3 tangent;
        if(length(c1) > length(c2))
            tangent = c1;
        else
            tangent = c2;

        tangent = normalize(tangent);
        vec3 bitangent = cross(normal, tangent);
        bitangent = normalize(bitangent);

        // The hemisphere is Y - up . Transform the Y axis to the normal
        vec3 s = SampleHemisphere();
        
        vec3 reflection = tangent * s.x + bitangent * s.z + normal * s.y;
        //vec3 reflection = DiffuseReflection(normal);

        
        float refractionOffset = 0;
        bool foundLight = false;
        switch(materialData[hitInfo.voxelID].type){
        case MATERIAL_GLASS:
            float cDot = dot(ray.d,normal);
            if(abs(cDot) > RandomFloat()){
                //reflection = refract(ray.d,normal,1.0 / materialData[hitInfo.voxelID].ior);
                reflection = refract(ray.d,normal,1.0);
                refractionOffset = 1.0;
            }
            else{
                reflection = reflect(ray.d,normal);
                //throughput *= cDot * INV2PI;
            }
            break;
        case MATERIAL_METAL:
            break;
        case MATERIAL_EMIT:
            finalColor.xyz += albedo
            * pow(materialData[hitInfo.voxelID].emit * 8.0,materialData[hitInfo.voxelID].flux)
            * throughput;

            foundLight = true;
            break;
        default:
            break;
        }
        if(foundLight){
            break;  
        }

        //float pdf = 1.0 / TWOPI;
        throughput *= albedo;

        const bool UsingRussianRoulette = true;
            if(UsingRussianRoulette && bounce > 0){
                float russianRoulette = max(throughput.x,max(throughput.y,throughput.z));
                if(RandomFloat() > russianRoulette){
                    break;
                }
                throughput *= 1 / russianRoulette;
            }

        ray.d = normalize(reflection);
        ray.o = I + ray.d * voxelSize * (EPS) + refractionOffset * -normal;
        ray.t = 1e30;
    }

    // if couln't find light after 4 bounces
    #ifdef HEATMAP
    if(heatMap){
        uint64_t elapsed = clockARB() - startTime;
        imageStore(imgOutput, pixel, vec4(float(elapsed) / heatMapThreshold ,0.0,0.0,1.0));
        return;
    }
    #endif
    imageStore(imgOutput,pixel, finalColor);
}

