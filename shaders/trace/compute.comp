#define BRICKSIZE 8
#define FULLBRICKSIZE BRICKSIZE*BRICKSIZE*BRICKSIZE 
// 8 in each direction
#define MAXSTEPS 24

uint IsSolidVoxel(uint brickOffset, uvec3 voxel){
    uint index = brickOffset + voxel.x + voxel.y * BRICKSIZE + voxel.z * BRICKSIZE * BRICKSIZE;

    // get integer 32 offset
    uint loadedMask = brickMaskData[index >> 5];
    
    uint bitIndex = index & 31;

    // mask with full integer
    uint customMask =  loadedMask & (1 << bitIndex); 

    return customMask;
}

uint GetVoxel(uint brickOffset, uvec3 voxel){
    uint index = brickOffset + voxel.x + voxel.y * BRICKSIZE + voxel.z * BRICKSIZE * BRICKSIZE;

    // to get short
    uint voxels4 = brickData[index >> 1];
    // index 0 || 1
    uint smallIndex = index & 1; 
    // get a ushort
    return (voxels4 >> (smallIndex * 16)) & 0xFFFF;
}


bool TraverseBrick(Ray localRay,uint brickIndex,int faxis,uvec3 brickCoord, in out float t,out uint voxelID, out vec3 normal){

    int axis = faxis;
    normal = vec3(0.0);

    // removing an epsilon
    float tEntry = t;
    vec3 localPos = localRay.o + localRay.d * tEntry;

    ivec3 vstep = ivec3(sign(localRay.d));

    // Instead of globalVoxel % BRICKSIZE, compute relative to known brick origin
    uvec3 brickBase = brickCoord * BRICKSIZE;
    uvec3 voxel = uvec3(clamp(
        ivec3(floor(localPos / voxelSize)) - ivec3(brickBase),
        ivec3(0),
        ivec3(BRICKSIZE - 1)
    ));
        
    vec3 nextVoxelBoundary;
    uvec3 globalVoxel = brickBase + voxel;

    nextVoxelBoundary.x = (vstep.x > 0) ?
        (float(globalVoxel.x) + 1.0) * voxelSize.x : float(globalVoxel.x) * voxelSize.x;
    nextVoxelBoundary.y = (vstep.y > 0) ?
        (float(globalVoxel.y) + 1.0) * voxelSize.y : float(globalVoxel.y) * voxelSize.y;
    nextVoxelBoundary.z = (vstep.z > 0) ?
        (float(globalVoxel.z) + 1.0) * voxelSize.z : float(globalVoxel.z) * voxelSize.z;

    // no 0 division
    const vec3 invdir = 1.0 / max(abs(localRay.d), vec3(0.000001));
    const vec3 tDelta = voxelSize * invdir;

    vec3 tMax = (nextVoxelBoundary - localPos) / localRay.d;


    if(voxel.x >= BRICKSIZE
    || voxel.y >= BRICKSIZE
    || voxel.z >= BRICKSIZE)
        return false;

    const uint brickOffset = brickIndex * FULLBRICKSIZE;
    uint val = GetVoxel(brickOffset, voxel);

    for(int n = 0; n < MAXSTEPS; n++){

        
        #ifdef USEMASK
        if(IsSolidVoxel(brickOffset,voxel) > 0){
            voxelID = 3;
            normal[axis] = -vstep[axis];
            return true;
        }
        #else
        // reading data
        if(val > 0){
            voxelID = val;
            normal[axis] = -vstep[axis];
            return true;
        }
        #endif

        #ifdef TESTTRAVERSAL

        if (tMax.x < tMax.y) {
            if(tMax.x < tMax.z){
                voxel.x += vstep.x;
                t = tEntry + tMax.x;
                tMax.x += tDelta.x;
                axis = 0;
                if(voxel.x >= BRICKSIZE)
                    return false;
            }
            else{
                voxel.z += vstep.z;
                t = tEntry + tMax.z;
                tMax.z += tDelta.z;
                axis = 2;
                if(voxel.z >= BRICKSIZE)
                    return false;
            }
        }
        else{
            if(tMax.y < tMax.z){
                voxel.y += vstep.y;
                t = tEntry + tMax.y;
                tMax.y += tDelta.y;
                axis = 1;
                if(voxel.y >= BRICKSIZE)
                    return false;
            }
            else{
                voxel.z += vstep.z;
                t = tEntry + tMax.z;
                tMax.z += tDelta.z;
                axis = 2;
                if(voxel.z >= BRICKSIZE)
                    return false;
            }
        }

        #else
        if (tMax.x < tMax.y && tMax.x < tMax.z) {
            voxel.x += vstep.x;
            t = tEntry + tMax.x;
            tMax.x += tDelta.x;
            axis = 0;
            if(voxel.x >= BRICKSIZE)
                return false;
        } else if (tMax.y < tMax.z) {
            voxel.y += vstep.y;
            t = tEntry + tMax.y;
            tMax.y += tDelta.y;
            axis = 1;
            if(voxel.y >= BRICKSIZE)
                return false;
        } else {
            voxel.z += vstep.z;
            t = tEntry + tMax.z;
            tMax.z += tDelta.z;
            axis = 2;
            if(voxel.z >= BRICKSIZE)
                return false;
        }
        #endif

        val = GetVoxel(brickOffset, voxel);
    }
    return false;
}



bool TraverseVolume(Ray localRay,uint voxelDataOffset,int faxis, ivec3 voxelBounds,in out float t,out uint voxelID, out vec3 normal){

    int axis = faxis;
    normal = vec3(0.0);

    // removing an epsilon
    float tEntry = t;
    const vec3 perBrickSize = voxelSize * BRICKSIZE;

    vec3 localPos = localRay.o + localRay.d * (tEntry);

    uvec3 brick = ivec3(floor(localPos / perBrickSize));
    const ivec3 bstep = ivec3(sign(localRay.d));
    

    vec3 nextBrickBoundary;
    nextBrickBoundary.x = (bstep.x > 0) ? 
        (float(brick.x) + 1.0) * perBrickSize.x : float(brick.x) * perBrickSize.x;
    nextBrickBoundary.y = (bstep.y > 0) ? 
        (float(brick.y) + 1.0) * perBrickSize.y : float(brick.y) * perBrickSize.y;
    nextBrickBoundary.z = (bstep.z > 0) ? 
        (float(brick.z) + 1.0) * perBrickSize.z : float(brick.z) * perBrickSize.z;

    // no 0 division
    vec3 invdir = 1.0 / max(abs(localRay.d), vec3(0.000001));

    vec3 tMax = (nextBrickBoundary - localPos) / localRay.d;
    vec3 tDelta = perBrickSize * invdir;


    uvec3 brickBounds = (voxelBounds + (BRICKSIZE - 1)) / BRICKSIZE;
      
    // should never happen really..
    if(brick.x >= brickBounds.x
    || brick.y >= brickBounds.y
    || brick.z >= brickBounds.z)
        return false;
    

    // safety measure. no while loop
    uint maxSteps = brickBounds.x + brickBounds.y + brickBounds.z;
    for(int n = 0; n < maxSteps; n++){

        // reading data
        uint brickIndex = voxelDataOffset + brick.x + brick.y * brickBounds.x + brick.z * brickBounds.x * brickBounds.y;
        uint brickAddress = bricks[brickIndex];
        
        if(brickAddress > 0){ // traverse brick
            float tempT = t;
            if(TraverseBrick(localRay, brickAddress, axis, brick, tempT,voxelID,normal)){
                t = tempT;
                return true;
            }
        }
        #ifdef TESTTRAVERSAL

        if (tMax.x < tMax.y) {
            if(tMax.x < tMax.z){
            brick.x += bstep.x;
            t = tEntry + tMax.x;
            tMax.x += tDelta.x;
            axis = 0;
            if(brick.x >= brickBounds.x)
                return false;
            }
            else{
            brick.z += bstep.z;
            t = tEntry + tMax.z;
            tMax.z += tDelta.z;
            axis = 2;
            if(brick.z >= brickBounds.z)
                return false;
            }
        }
        else{
            if(tMax.y < tMax.z){
            brick.y += bstep.y;
            t = tEntry + tMax.y;
            tMax.y += tDelta.y;
            axis = 1;
            if(brick.y >= brickBounds.y)
                return false;
            }
            else{
            brick.z += bstep.z;
            t = tEntry + tMax.z;
            tMax.z += tDelta.z;
            axis = 2;
            if(brick.z >= brickBounds.z)
                return false;
            }
        }

        #else
        if (tMax.x < tMax.y && tMax.x < tMax.z) {
            brick.x += bstep.x;
            t = tEntry + tMax.x;
            tMax.x += tDelta.x;
            axis = 0;
            if(brick.x >= brickBounds.x)
                return false;
        } else if (tMax.y < tMax.z) {
            brick.y += bstep.y;
            t = tEntry + tMax.y;
            tMax.y += tDelta.y;
            axis = 1;
            if(brick.y >= brickBounds.y)
                return false;
        } else {
            brick.z += bstep.z;
            t = tEntry + tMax.z;
            tMax.z += tDelta.z;
            axis = 2;
            if(brick.z >= brickBounds.z)
                return false;
        }
        #endif
    }
    return false;
}





void Intersect(inout Ray ray,inout HitInfo info, in Volume volume){

    ray.o = (volume.invModel * vec4(ray.o,1.0)).xyz; 
    ray.d = (volume.invModel * vec4(ray.d,0.0)).xyz; 

    // in the volumes object space
    vec4 localMin = vec4(0.0);
    vec4 localMax = vec4(vec3(volume.voxelDims) * voxelSize, 1.0);
    HitResult result = IntersectAABB(ray,localMin,localMax);


    if(result.hit){
        float tEntry = max(result.tmin,0.0);
        uint voxelID = 0;
        vec3 normal;
        float tHit = tEntry + 0.0005;
        if(TraverseVolume(ray,volume.startBrickIndex,result.axis, volume.voxelDims.xyz, tHit, voxelID, normal)){
            if(tHit < ray.t){
                ray.t = tHit;
                info.voxelID = voxelID;
                info.normal = normalize((volume.model * vec4(normal,0.0)).xyz);
            }
        }
    }
}





// normal
// bvh traversal
void Trace(inout Ray ray,inout HitInfo info){

    info.voxelID = 0;
    Ray cachedRay = ray;

    // instead of recursive
    // have a stack
    uint stack[24];
    uint stackPtr = 0;

    TLASNode currentNode = tlasNodes[0];
    for(int e = 0; e < 1000; e++){

        if(BLASCOUNT(currentNode) > 0){ // isleaf()
            uint instanceID = instanceList[TLASLEFTRIGHT(currentNode)];

            Intersect(ray,info,voxelVolumes[instanceID]);
            // turn ray back to world space
            ray.o = cachedRay.o;
            ray.d = cachedRay.d;

            if(stackPtr == 0) 
                    break;
                else
                    currentNode  = tlasNodes[stack[--stackPtr]];
                continue;
        }
        
        // 0xffff == 65535
        uint left  = TLASLEFTRIGHT(currentNode);
        uint right = left + 1;
        TLASNode child1 = tlasNodes[left];
        TLASNode child2 = tlasNodes[right];

        float dist1 = IntersectAABBFloat( ray, child1.aabbmin,child1.aabbmax);
        float dist2 = IntersectAABBFloat( ray, child2.aabbmin,child2.aabbmax);
        if(dist1 > dist2){
            float d = dist1;
            dist1 = dist2;
            dist2 = d;
            TLASNode c = child1;
            child1 = child2;
            child2 = c;
            
            uint temp = left;
            left = right;
            right = temp;
        }
        if(dist1 == 1e30){
            // missed both children nodes
            if(stackPtr == 0)
                break;
            else
                currentNode = tlasNodes[stack[--stackPtr]];
        }
        else
        {
            // visit near node;
            // push far node if ray intersects
            currentNode = child1;
            if(dist2 != 1e30)   // the right node gets pushed on the stack
                stack[stackPtr++] = right;
        }
    }
}







vec3 direction(vec3 normal, vec2 randomValues, float maxTheta) {
    vec3 tangent = (normal.x > normal.z) ? vec3(-normal.y, normal.x, 0.0) : vec3(0.0, -normal.z, normal.y);
    // and a bitangent vector orthogonal to both
    vec3 bitangent = cross(normal, tangent);

    float phi = 2.0 * PI * randomValues.x;
    float theta = randomValues.y * maxTheta;
    float sinTheta = sin(theta);
    return tangent * cos(phi) * sinTheta + bitangent * sin(phi) * sinTheta + normal * cos(theta);
}



// not being used currently
vec3 DiffuseReflection(vec3 normal){
    
    int k = 0;
    vec3 reflection;
    do
    {
        reflection = vec3(RandomFloat(),RandomFloat(),RandomFloat()) * 2 - 1;
        k++;

        if(k > 300)
            return vec3(1.0);
    } while(dot(reflection,normal) > 1);

    return normalize(dot(normal,reflection) < 0 ? -reflection : reflection);
}


// Ray Tracing using HIP.pdf
// input uniform random floats
vec3 SampleHemisphere(){
    
    vec2 rand = vec2(RandomFloat(),RandomFloat());
    //vec2 rand = SampleBlueNoise2D();

    vec3 dir = vec3(0);
    float phi = TWOPI * rand.x;
    float r   = sqrt(rand.y);
    // uniform in circle
    dir.x = r * cos(phi);
    dir.z = r * sin(phi);

    // project onto hemisphere
    dir.y = sqrt(max(1.0 - r * r, 0.0));

    return dir;
}



