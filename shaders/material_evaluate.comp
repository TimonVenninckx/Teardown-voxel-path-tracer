void StoreShadowRay(vec3 origin, vec3 normal, vec3 throughput, ivec2 pixel){

    uint lightIndex = RandomUint() % lightCount;
    
    float dist = 1.0;
    vec3 dir = vec3(1.0);

    float distanceAttenuation = 1.0;
    switch(lightData[lightIndex].type){
        case 0:{ // Dir light
            // negate direction as we are trying to go towards the light
            dir = normalize(-lightData[lightIndex].direction.xyz);
            // small offset for self-occlusion
            dist = 1e30;
            break;
        }
        case 1: { // point light
            dir = lightData[lightIndex].position.xyz - origin;
            dist = length(dir);
            dir /= dist;
            distanceAttenuation = 1 / (dist * dist);
            break;
        }
        case 2: {// spotlight
            dir = lightData[lightIndex].position.xyz - origin;
            dist = length(dir);
            dir /= dist;

            vec3 negatedSpotLightDir = normalize(-lightData[lightIndex].direction.xyz);
            // https://gamedev.stackexchange.com/questions/69475/how-do-i-use-the-dot-product-to-get-an-angle-between-two-vectors
            // both normalized angle = arccos(dot(A,B) / (|A|* |B|)).
            // https://learnopengl.com/Lighting/Light-casters
            float theta = dot(dir,negatedSpotLightDir);
            // early out
            if(theta < lightData[lightIndex].outerCutOff){
                return;
            }
            distanceAttenuation = 1 / (dist * dist);
            break;
        }
    }

    float cosa = dot(dir,normal);
    if(cosa <= 0.0)
        return; 


    origin += EPS * voxelSize * mix(normal,dir, cosa);

    RayCastInfo i;
    i.o.xyz = origin;
    
    i.d.xyz = dir;
    i.d.w = dist;

    vec3 light = lightData[lightIndex].color.xyz * distanceAttenuation;
    i.throughput.xyz = throughput * light * cosa * lightCount;

    ivec2 size = imageSize(imgOutput);
    int pixelIndex = pixel.x + pixel.y * size.x;
    i.throughput.w = intBitsToFloat(pixelIndex);

    uint atomicIndex = atomicAdd(writeIndexShadow, 1);
    rayListShadow[atomicIndex] = i;
};


void GetRayCastInfo(out vec3 origin, out vec3 dir, out vec3 throughput, out ivec2 pixel, out uint seed, out bool hitMirror, out bool startingInside, out uint material, uint index){
    
    RayCastInfo i;
    
    i = rayReadList[index];
    
    origin = i.o.xyz;
    material = floatBitsToUint(i.o.w);
    //uint flags = floatBitsToUint(i.o.w);
    //hitMirror = bool(1 & flags);
    //startingInside = bool(2  & flags);

    dir = i.d.xyz;
    seed = floatBitsToUint(i.d.w);
    throughput = i.throughput.xyz;
    int pixelIndex = floatBitsToInt(i.throughput.w);
    
    ivec2 size = imageSize(imgOutput);
    pixel.x = pixelIndex % size.x;
    pixel.y = pixelIndex / size.x;

}

// Encode
vec2 OctWrap(vec2 v) {
    return (1.0 - abs(v.yx)) * sign(v.xy);
}

vec2 encodeNormal(vec3 n) {
    n /= (abs(n.x) + abs(n.y) + abs(n.z));
    n.xy = n.z >= 0.0 ? n.xy : OctWrap(n.xy);
    return n.xy * 0.5 + 0.5; // pack to [0, 1]
}

vec3 decodeNormal(vec2 enc) {
    enc = enc * 2.0 - 1.0;
    vec3 n = vec3(enc.x, enc.y, 1.0 - abs(enc.x) - abs(enc.y));
    float t = clamp(-n.z, 0.0, 1.0);
    n.xy -= sign(n.xy) * t;
    return normalize(n);
}



bool ReadRay(out Ray ray, out vec3 throughput, out ivec2 pixel, out vec3 normal, out uint material){

    uint index = atomicAdd(rayReadIndex, 1);
    if(index >= rayMaxReadIndex)
        return false;

    bool test;
    GetRayCastInfo(ray.o, ray.d, throughput,pixel,g_seed,test,test,material, index);

    
    ShadeInfo s;
    s = rayShadeList[index];
    normal = decodeNormal(s.material.zw);
    ray.t = s.material.y;// s.normalDepth.w;
    material = floatBitsToUint(s.material.x);

    return true;
}



void main(){
    const ivec2 size = imageSize(imgOutput);
    Ray ray;
    vec3 throughput;
    ivec2 pixel;
    vec3  normal;
    uint material;

    
    bool rayStartedInside = false; // TEMP
    bool previouslyHitMirror = false;

    while(true){

        if(!ReadRay(ray,throughput,pixel,normal,material))
            return;

        vec4 finalColor = vec4(0,0,0,1);
        
        bool foundLight = false;
        vec3 albedo = materialData[material].color;
        if(material == 0){
            // equirectangular panorama texture sampling with ray.d
            // https://jacco.ompf2.com/2022/05/27/how-to-build-a-bvh-part-8-whitted-style/
            float domeu = (atan(ray.d.z,ray.d.x) * INV2PI + 0.5);
            float domev = (acos(ray.d.y) * INVPI);
            vec4 backGroundColor =  texture(skydome,vec2(domeu,domev));
            foundLight = true;
            albedo = backGroundColor.xyz;
            finalColor.xyz += throughput * backGroundColor.xyz;
        }

        albedo = max(albedo,0.00001);

        vec3 I = ray.o + ray.d * ray.t;
        
        // https://jacco.ompf2.com/2024/05/29/ray-tracing-with-voxels-in-c-series-part-6/
        vec3 brdf = albedo * INVPI;

        vec3 c1 = cross(normal, vec3(0.0, 0.0, 1.0));
        vec3 c2 = cross(normal, vec3(0.0, 1.0, 0.0));

        vec3 tangent = length(c1) > length(c2)? c1 : c2;

        tangent = normalize(tangent);
        vec3 bitangent = cross(normal, tangent);
        bitangent = normalize(bitangent);

        // The hemisphere is Y - up . Transform the Y axis to the normal
        vec3 s = SampleHemisphere();
        vec3 reflection = tangent * s.x + bitangent * s.z + normal * s.y;


        bool refractingInwards = rayStartedInside;
        bool hitMirror = false;
        switch(materialData[material].type){
        case MATERIAL_GLASS:
            hitMirror = true;
            float ior = materialData[material].ior;
            float eta = rayStartedInside ? ior : 1.0 / ior;
            float cDot = dot(normal, ray.d);
            float k = 1.0 - eta * eta * (1.0 - cDot * cDot);
            if(k > 0.0 && RandomFloat() < k){
                reflection = eta * ray.d - (eta * cDot + sqrt(k)) * normal;
                refractingInwards = !rayStartedInside;
            }
            else{
                reflection = reflect(ray.d,normal);
            }
            break;
        case MATERIAL_EMIT:
            finalColor.xyz += albedo
            * pow(materialData[material].emit * 8.0,materialData[material].flux)
            * throughput;

            //  * (1 / ray.t * ray.t) doesn't seem to do anything here.

            foundLight = true;
            break;
        default:
            break;
        }

        if(foundLight){
            finalColor.xyz += imageLoad(imgOutput,pixel).xyz;
            imageStore(imgOutput, pixel, finalColor);
        }
        else{
            const bool beersLaw = false;
            if(beersLaw && rayStartedInside){ // beers law
                vec3 absorbtion = exp(-albedo * ray.t * voxelSize);
                throughput *= absorbtion;
            }
            else
                throughput *= albedo;

            const bool UsingRussianRoulette = true;
            if(UsingRussianRoulette){
                float russianRoulette = max(throughput.x,max(throughput.y,throughput.z));
                if(RandomFloat() >= russianRoulette){
                    continue;
                }
                throughput *= 1 / russianRoulette;
            }
            ray.d = normalize(reflection);
            ray.o = I + ray.d * voxelSize * (EPS);

            
            StoreShadowRay(I,normal,throughput,pixel);

            if(!lastBounce)                         //  AKA IF FIRST ALBEDO HAS BEEN FOUND
                StoreRay(ray.o,ray.d,throughput,pixel,hitMirror && previouslyHitMirror, refractingInwards);
        }

        if(previouslyHitMirror && !hitMirror){
            //imageStore(albedoBuffer,pixel,vec4(max(albedo,0.000001),1.0));
        }
    }
}

