layout(binding = 0, offset = 0) uniform atomic_uint aReadIndexA;
layout(binding = 0, offset = 4) uniform atomic_uint aWriteIndexA;
layout(binding = 0, offset = 8) uniform atomic_uint aReadIndexB;
layout(binding = 0, offset = 12) uniform atomic_uint aWriteIndexB;
void StoreRay(vec3 origin, vec3 dir, vec3 throughput, ivec2 pixel){
    RayCastInfo i;
    i.o.xyz = origin;
    i.d.xyz = dir;
    i.throughput.xyz = throughput;

    i.d.w = uintBitsToFloat(g_seed);
    
    ivec2 size = imageSize(imgOutput);
    int pixelIndex = pixel.x + pixel.y * size.x;
    i.throughput.w = intBitsToFloat(pixelIndex);

    if(readingBufferA){ // then we are writing to B
        int index = atomicAdd(writeIndexB, 1);
        //uint index = atomicCounterIncrement(aWriteIndexB);
        rayListB[index] = i;
    }else{
        int index = atomicAdd(writeIndexA, 1);
        //uint index = atomicCounterIncrement(aWriteIndexA);
        rayListA[index] = i;
    }
}


bool GetRayCastInfo(out vec3 origin, out vec3 dir, out vec3 throughput, out ivec2 pixel, out uint seed){
    
    RayCastInfo i;
    if(readingBufferA){
        int index = atomicAdd(readIndexA, 1);
        //uint index = atomicCounterIncrement(aReadIndexA);
        if(index > writeIndexA)
            return false;
        i = rayListA[index];
    }else{
        int index = atomicAdd(readIndexB, 1);
        //uint index = atomicCounterIncrement(aReadIndexB);
        if(index > writeIndexB)
            return false;
        i = rayListB[index];
    }

    origin = i.o.xyz;
    dir = i.d.xyz;
    seed = floatBitsToUint(i.d.w);
    throughput = i.throughput.xyz;
    
    ivec2 size = imageSize(imgOutput);
    int pixelIndex = floatBitsToInt(i.throughput.w);
    pixel.x = pixelIndex % size.x;
    pixel.y = pixelIndex / size.x;

    return true;
}



