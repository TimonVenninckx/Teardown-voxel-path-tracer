vec2 blueNoiseTexCoord = vec2(0);

// from teardown
// great way to sample blue noise
const float GOLDEN_RATIO_1D = 0.618034005;
const vec2  GOLDEN_RATIO_2D = vec2(0.75487762, 0.56984027);
const vec3  GOLDEN_RATIO_3D = vec3(0.819172502, 0.671043575, 0.549700439);

void InitializeBlueNoise(vec2 screenCoord){

    // blue noise texture size
    blueNoiseTexCoord  = (screenCoord * resolution) / 512.0;
}

float SampleBlueNoise1D(){
    
    float noiseValue = texture(blueNoise,blueNoiseTexCoord).r;
    float randomValue = fract(noiseValue + GOLDEN_RATIO * frameRandomSeed);

    blueNoiseTexCoord += GOLDEN_RATIO_1D;
    return randomValue;
}


vec2 SampleBlueNoise2D(){
    
    vec2 noiseValue = texture(blueNoise,blueNoiseTexCoord).rg;
    vec2 randomValue = fract(noiseValue + GOLDEN_RATIO * frameRandomSeed);

    blueNoiseTexCoord += GOLDEN_RATIO_2D;
    return randomValue;
}

vec3 SampleBlueNoise3D(){
    
    vec3 noiseValue = texture(blueNoise,blueNoiseTexCoord).rgb;
    vec3 randomValue = fract(noiseValue + GOLDEN_RATIO * frameRandomSeed);

    blueNoiseTexCoord += GOLDEN_RATIO_2D;
    return randomValue;
}


void InitializeSeed(uint s)
{
    s = (s ^ 61) & (s >> 16);
    s *= 9;
    s = s ^ (s >> 4);
    s *= 0x27d4eb2d;
    g_seed = s ^ (s >> 15);
}

uint RandomUint(){
    g_seed ^= g_seed << 13;
    g_seed ^= g_seed >> 17;
    g_seed ^= g_seed << 5;

    return g_seed;
}

// float from 0-1
float RandomFloat(){
    uint rng = RandomUint();

    return float(rng) * 2.3283064365387e-10;
}



struct HitInfo{
    vec3 normal;
    // used to check if hit
    uint voxelID;
};



struct HitResult{
    bool hit;
    float tmin;
    float tmax;
    int axis;
};


float IntersectAABBFloat(const Ray ray, const vec3 bmin, const vec3 bmax){
    vec3 invDir = 1.0 / max(abs(ray.d), vec3(1e-6)) * sign(ray.d);

    float tx1 = (bmin.x - ray.o.x) * invDir.x;
    float tx2 = (bmax.x - ray.o.x) * invDir.x;
    float tmin = min(tx1,tx2);
    float tmax = max(tx1,tx2);
    float ty1 = (bmin.y - ray.o.y) * invDir.y;
    float ty2 = (bmax.y - ray.o.y) * invDir.y;
    tmin = max(tmin,min(ty1,ty2));
    tmax = min(tmax,max(ty1,ty2));
    float tz1 = (bmin.z - ray.o.z) * invDir.z;
    float tz2 = (bmax.z - ray.o.z) * invDir.z;
    tmin = max(tmin,min(tz1,tz2));
    tmax = min(tmax,max(tz1,tz2));

    if(tmax >= tmin && tmin < ray.t && tmax > 0)
        return tmin;
    return 1e30;
}


HitResult IntersectAABB(const Ray ray, const vec3 bmin, const vec3 bmax){
    vec3 invDir = 1.0 / max(abs(ray.d), vec3(1e-6)) * sign(ray.d);
    HitResult result;
    result.hit = false;
    result.axis = -1;
    result.tmin = -1e30;
    result.tmax =  1e30;


    float tx1 = (bmin.x - ray.o.x) * invDir.x;
    float tx2 = (bmax.x - ray.o.x) * invDir.x;
    float txmin = min(tx1,tx2);
    float txmax = max(tx1,tx2);
    if(txmin > result.tmin){
        result.tmin = txmin;
        result.axis = 0;
    }
    result.tmax = min(result.tmax,txmax);


    float ty1 = (bmin.y - ray.o.y) * invDir.y;
    float ty2 = (bmax.y - ray.o.y) * invDir.y;
    float tymin = min(ty1,ty2);
    float tymax = max(ty1,ty2);
    if(tymin > result.tmin){
        result.tmin = tymin;
        result.axis = 1;
    }
    result.tmax = min(result.tmax,tymax);

    float tz1 = (bmin.z - ray.o.z) * invDir.z;
    float tz2 = (bmax.z - ray.o.z) * invDir.z;
    float tzmin = min(tz1,tz2);
    float tzmax = max(tz1,tz2);
    if(tzmin > result.tmin){
        result.tmin = tzmin;
        result.axis = 2;
    }
    result.tmax = min(result.tmax,tzmax);


    if(result.tmax >= result.tmin && result.tmin < ray.t && result.tmax > 0)
        result.hit = true;
    return result;
}



#define BRICKSIZE 8

#define FULLBRICKSIZE BRICKSIZE*BRICKSIZE*BRICKSIZE 
// 8 in each direction
#define MAXSTEPS 24

uint GetVoxel(uint brickOffset, uvec3 voxel){
    uint index = brickOffset + voxel.x + voxel.y * BRICKSIZE + voxel.z * BRICKSIZE * BRICKSIZE;

    //return brickData[index];
    // divide by 4
    uint voxels4 = brickData[index >> 2];
    // number from 0-3
    uint smallIndex = index & 3; 

    return (voxels4 >> (smallIndex * 8)) & 255;
}
bool TraverseBrick(Ray localRay,uint brickIndex,int faxis,in out float t,out uint voxelID, out vec3 normal){

    int axis = faxis;
    normal = vec3(0.0);

    // removing an epsilon
    float tEntry = t;
    vec3 localPos = localRay.o + localRay.d * (tEntry + voxelSize.x * EPS * 2);
    vec3 maxPos = localRay.o + localRay.d * (tEntry + voxelSize.x * EPS * 10);

    ivec3 vstep = ivec3(sign(localRay.d));

    uvec3 globalVoxel = ivec3(floor(localPos / voxelSize));
    // number from 0-BRICKSIZE
    uvec3 voxel = globalVoxel % BRICKSIZE;
        
    vec3 nextVoxelBoundary;
    nextVoxelBoundary.x = (vstep.x > 0) ? 
        (float(globalVoxel.x) + 1.0) * voxelSize.x : float(globalVoxel.x) * voxelSize.x;
    nextVoxelBoundary.y = (vstep.y > 0) ? 
        (float(globalVoxel.y) + 1.0) * voxelSize.y : float(globalVoxel.y) * voxelSize.y;
    nextVoxelBoundary.z = (vstep.z > 0) ? 
        (float(globalVoxel.z) + 1.0) * voxelSize.z : float(globalVoxel.z) * voxelSize.z;

    // no 0 division
    const vec3 invdir = 1.0 / max(abs(localRay.d), vec3(0.000001));
    const vec3 tDelta = voxelSize * invdir;

    vec3 tMax = (nextVoxelBoundary - maxPos) / localRay.d;


    if(voxel.x >= BRICKSIZE
    || voxel.y >= BRICKSIZE
    || voxel.z >= BRICKSIZE)
        return false;

    const uint brickOffset = brickIndex * FULLBRICKSIZE;
    for(int n = 0; n < MAXSTEPS; n++){

        // reading data
        uint val = GetVoxel(brickOffset, voxel);
        if(val > 0){
            voxelID = val;
            normal[axis] = -vstep[axis];
            return true;
        }

        if (tMax.x < tMax.y && tMax.x < tMax.z) {
            voxel.x += vstep.x;
            t = tEntry + tMax.x;
            tMax.x += tDelta.x;
            axis = 0;
            if(voxel.x >= BRICKSIZE)
                return false;
        } else if (tMax.y < tMax.z) {
            voxel.y += vstep.y;
            t = tEntry + tMax.y;
            tMax.y += tDelta.y;
            axis = 1;
            if(voxel.y >= BRICKSIZE)
                return false;
        } else {
            voxel.z += vstep.z;
            t = tEntry + tMax.z;
            tMax.z += tDelta.z;
            axis = 2;
            if(voxel.z >= BRICKSIZE)
                return false;
        }
    }
    return false;
}



bool TraverseVolume(Ray localRay,uint voxelDataOffset,int faxis, ivec3 voxelBounds,in out float t,out uint voxelID, out vec3 normal){

    int axis = faxis;
    normal = vec3(0.0);

    // removing an epsilon
    float tEntry = t;
    const vec3 perBrickSize = voxelSize * BRICKSIZE;

    vec3 localPos = localRay.o + localRay.d * (tEntry);

    uvec3 brick = ivec3(floor(localPos / perBrickSize));
    const ivec3 bstep = ivec3(sign(localRay.d));
    

    vec3 nextBrickBoundary;
    nextBrickBoundary.x = (bstep.x > 0) ? 
        (float(brick.x) + 1.0) * perBrickSize.x : float(brick.x) * perBrickSize.x;
    nextBrickBoundary.y = (bstep.y > 0) ? 
        (float(brick.y) + 1.0) * perBrickSize.y : float(brick.y) * perBrickSize.y;
    nextBrickBoundary.z = (bstep.z > 0) ? 
        (float(brick.z) + 1.0) * perBrickSize.z : float(brick.z) * perBrickSize.z;

    // no 0 division
    vec3 invdir = 1.0 / max(abs(localRay.d), vec3(0.000001));

    vec3 tMax = (nextBrickBoundary - localPos) / localRay.d;
    vec3 tDelta = perBrickSize * invdir;


    uvec3 brickBounds = (voxelBounds + (BRICKSIZE - 1)) / BRICKSIZE;
      
    // should never happen really..
    if(brick.x >= brickBounds.x
    || brick.y >= brickBounds.y
    || brick.z >= brickBounds.z)
        return false;
    

    // safety measure. no while loop
    uint maxSteps = brickBounds.x + brickBounds.y + brickBounds.z;
    for(int n = 0; n < maxSteps; n++){

        // reading data
        uint brickIndex = voxelDataOffset + brick.x + brick.y * brickBounds.x + brick.z * brickBounds.x * brickBounds.y;
        uint brickAddress = bricks[brickIndex];
        
        if(brickAddress > 0){ // traverse brick
            float tempT = t;
            if(TraverseBrick(localRay, brickAddress, axis, tempT,voxelID,normal)){
                t = tempT;
                return true;
            }
        }

        if (tMax.x < tMax.y && tMax.x < tMax.z) {
            brick.x += bstep.x;
            t = tEntry + tMax.x;
            tMax.x += tDelta.x;
            axis = 0;
            if(brick.x >= brickBounds.x)
                return false;
        } else if (tMax.y < tMax.z) {
            brick.y += bstep.y;
            t = tEntry + tMax.y;
            tMax.y += tDelta.y;
            axis = 1;
            if(brick.y >= brickBounds.y)
                return false;
        } else {
            brick.z += bstep.z;
            t = tEntry + tMax.z;
            tMax.z += tDelta.z;
            axis = 2;
            if(brick.z >= brickBounds.z)
                return false;
        }
    }
    return false;
}





void Intersect(inout Ray ray,inout HitInfo info, in Volume volume){

    ray.o = (volume.invModel * vec4(ray.o,1.0)).xyz; 
    ray.d = (volume.invModel * vec4(ray.d,0.0)).xyz; 

    // in the volumes object space
    vec3 localMin = vec3(0.0);
    vec3 localMax = vec3(volume.voxelDims.xyz) * voxelSize;
    HitResult result = IntersectAABB(ray,localMin,localMax);


    if(result.hit){
        float tEntry = max(result.tmin,0.0);

        uint voxelID = 0;
        vec3 normal;
        float tHit = tEntry + (voxelSize.x * EPS);
        if(TraverseVolume(ray,volume.startBrickIndex,result.axis, volume.voxelDims.xyz, tHit, voxelID, normal)){
            if(tHit < ray.t){
                ray.t = tHit;
                info.voxelID = voxelID;
                info.normal = normalize((volume.model * vec4(normal,0.0)).xyz);
            }
        }
    }
}





// normal
// bvh traversal
void Trace(inout Ray ray,inout HitInfo info){

    info.voxelID = 0;
    Ray cachedRay = ray;

    // instead of recursive
    // have a stack
    uint stack[24];
    uint stackPtr = 0;

    TLASNode currentNode = tlasNodes[0];
    for(int e = 0; e < 1000; e++){

        if(BLASCOUNT(currentNode) > 0){ // isleaf()
            uint instanceID = instanceList[TLASLEFTRIGHT(currentNode)];

            Intersect(ray,info,voxelVolumes[instanceID]);
            // turn ray back to world space
            ray.o = cachedRay.o;
            ray.d = cachedRay.d;

            if(stackPtr == 0) 
                    break;
                else
                    currentNode  = tlasNodes[stack[--stackPtr]];
                continue;
        }
        
        // 0xffff == 65535
        uint left  = TLASLEFTRIGHT(currentNode);
        uint right = left + 1;
        TLASNode child1 = tlasNodes[left];
        TLASNode child2 = tlasNodes[right];

        float dist1 = IntersectAABBFloat( ray, child1.aabbmin.xyz,child1.aabbmax.xyz);
        float dist2 = IntersectAABBFloat( ray, child2.aabbmin.xyz,child2.aabbmax.xyz);
        if(dist1 > dist2){
            float d = dist1;
            dist1 = dist2;
            dist2 = d;
            TLASNode c = child1;
            child1 = child2;
            child2 = c;
            
            uint temp = left;
            left = right;
            right = temp;
        }
        if(dist1 == 1e30){
            // missed both children nodes
            if(stackPtr == 0)
                break;
            else
                currentNode = tlasNodes[stack[--stackPtr]];
        }
        else
        {
            // visit near node;
            // push far node if ray intersects
            currentNode = child1;
            if(dist2 != 1e30)   // the right node gets pushed on the stack
                stack[stackPtr++] = right;
        }
    }
}

// bvh traversal
bool TraceIsOccluded(Ray ray){

    HitInfo info;
    info.voxelID = 0;
    Ray cachedRay = ray;

    // instead of recursive
    // have a stack
    uint stack[24];
    uint stackPtr = 0;

    TLASNode currentNode = tlasNodes[0];
    for(int e = 0; e < 1000; e++){

        if(BLASCOUNT(currentNode) > 0){ // isleaf()
            uint instanceID = instanceList[TLASLEFTRIGHT(currentNode)];

            Intersect(ray,info,voxelVolumes[instanceID]);
            if(info.voxelID > 0)
                return true;
            
            // turn ray back to world space
            ray.o = cachedRay.o;
            ray.d = cachedRay.d;

            if(stackPtr == 0) 
                break;
            else
                currentNode  = tlasNodes[stack[--stackPtr]];
            continue;
        }
        
        // 0xffff == 65535
        uint left  = TLASLEFTRIGHT(currentNode);
        uint right = left + 1;
        TLASNode child1 = tlasNodes[left];
        TLASNode child2 = tlasNodes[right];

        float dist1 = IntersectAABBFloat( ray, child1.aabbmin.xyz,child1.aabbmax.xyz);
        float dist2 = IntersectAABBFloat( ray, child2.aabbmin.xyz,child2.aabbmax.xyz);
        if(dist1 > dist2){
            float d = dist1;
            dist1 = dist2;
            dist2 = d;
            TLASNode c = child1;
            child1 = child2;
            child2 = c;
            
            uint temp = left;
            left = right;
            right = temp;
        }
        if(dist1 == 1e30){
            // missed both children nodes
            if(stackPtr == 0)
                break;
            else
                currentNode = tlasNodes[stack[--stackPtr]];
        }
        else
        {
            // visit near node;
            // push far node if ray intersects
            currentNode = child1;
            if(dist2 != 1e30)   // the right node gets pushed on the stack
                stack[stackPtr++] = right;
        }
    }
    return false;
}








vec3 direction(vec3 normal, vec2 randomValues, float maxTheta) {
    vec3 tangent = (normal.x > normal.z) ? vec3(-normal.y, normal.x, 0.0) : vec3(0.0, -normal.z, normal.y);
    // and a bitangent vector orthogonal to both
    vec3 bitangent = cross(normal, tangent);

    float phi = 2.0 * PI * randomValues.x;
    float theta = randomValues.y * maxTheta;
    float sinTheta = sin(theta);
    return tangent * cos(phi) * sinTheta + bitangent * sin(phi) * sinTheta + normal * cos(theta);
}



// not being used currently
vec3 DiffuseReflection(vec3 normal){
    
    int k = 0;
    vec3 reflection;
    do
    {
        reflection = vec3(RandomFloat(),RandomFloat(),RandomFloat()) * 2 - 1;
        k++;

        if(k > 300)
            return vec3(1.0);
    } while(dot(reflection,normal) > 1);

    return normalize(dot(normal,reflection) < 0 ? -reflection : reflection);
}


// Ray Tracing using HIP.pdf
// input uniform random floats
vec3 SampleHemisphere(){
    
    vec2 rand = vec2(RandomFloat(),RandomFloat());
    //vec2 rand = SampleBlueNoise2D();

    vec3 dir = vec3(0);
    float phi = TWOPI * rand.x;
    float r   = sqrt(rand.y);
    // uniform in circle
    dir.x = r * cos(phi);
    dir.z = r * sin(phi);

    // project onto hemisphere
    dir.y = sqrt(max(1.0 - r * r, 0.0));

    return dir;
}


bool ProjectOntoShadowMap(vec3 samplePosition){

    const vec3 right    = sunTopRight   - sunTopLeft;
    const vec3 down     = sunBottomLeft - sunTopLeft;
    const vec3 planeNormal = normalize(cross(right, down));

    vec3 toSample = samplePosition - sunPosition;

    // project ray ont sun direction ray
    float denom = dot(toSample, planeNormal);
    // gives you distance of plane along normal / distance of sample point along normal
    float t = dot(sunTopLeft - sunPosition, planeNormal) / denom;
    
    // point on the screen-plane
    vec3 hitPoint = sunPosition + t * toSample;

    // calculate UV on the plane
    vec3 offset = hitPoint - sunTopLeft;
    float u = dot(offset, right) / dot(right, right); // length squared
    float v = dot(offset, down)  / dot(down,  down);  // length squared

    // skip samples outside the shadow map
    if(u >= 0.0 && u <= 1.0 && v >= 0.0 && v <= 1.0){
        float closestDepth = texture(shadowMap, vec2(u, v)).r;
        float currentDepth = length(toSample) / 200.0;
        if(currentDepth > closestDepth)
            return false;
    }
    // if outside of shadow map just full-bright
    return true;
}










void main(){
    
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    // get screen size
    ivec2 size = imageSize(imgOutput);
    if(pixel.x >= size.x || pixel.y >= size.y)
        return;

    uint pixelHash = pixel.x * 73856093u 
                ^ pixel.y * 19349663u 
                ^ frameNumber * 83492791u;

    InitializeSeed(pixelHash);
    
    // coords from 0-1
    // reverse the V coord
    float u = (float(pixel.x) + RandomFloat()) / float(size.x);
    float v = (float(pixel.y) + RandomFloat()) / float(size.y);

    // get ray dir
    // point on the screen-plane
    vec3 point = cTopLeft + 
                    u * (cTopRight - cTopLeft) + 
                    v * (cBottomLeft - cTopLeft); 
    
    vec3 throughput;

    
    
    Ray ray;
    ray.o = camPos;
    ray.d = normalize(point - camPos);
    ray.t = 1e30;

    StoreRay(ray.o,ray.d,throughput,pixel);
    imageStore(imgOutput,pixel,vec4(0));
}

